# EdgePulse 2026 Orchestrator Configuration

# Web Server Configuration
PORT=8000

# MQTT Telemetry Broker Configuration
MQTT_BROKER_URL=127.0.0.1

# Option A: Local Llama Server Endpoint
LLAMA_SERVER_URL=http://localhost:8080/completion

# Option B: Google Gemini API Credentials
# If GEMINI_API_KEY is defined, the system will use Gemini instead of llama-server.
# GEMINI_API_KEY=AIzaSy...
